---
import type { File } from "@/services/types";
import ButtonMenu from "./ButtonMenu.astro";

interface Props {
  files: File[];
  folderId?: number;
}

const { files, folderId } = Astro.props;
---

<script>
  interface SearchResult {
    element: HTMLElement;
    matchScore: number;
  }

  /**
   * Tokenizes text into words for full-text search.
   * Splits on whitespace and common punctuation.
   */
  function tokenize(text: string): string[] {
    return text
      .toLowerCase()
      .split(/\s+|[\-_.\/]/g)
      .filter((token) => token.length > 0);
  }

  /**
   * Performs full-text search with tokenization.
   * Searches both file name and content.
   * All search terms must be present (AND logic).
   * Returns a match score based on relevance.
   */
  function performFullTextSearch(
    fileName: string,
    fileContent: string,
    searchTerms: string[],
  ): number | null {
    if (searchTerms.length === 0) return 1; // No search = show all

    // Combine name and content for searching
    const searchableText = `${fileName} ${fileContent}`;
    const searchableTokens = tokenize(searchableText);
    const searchableStr = searchableTokens.join(" ");

    // Check if all search terms exist in the combined text
    const allTermsMatch = searchTerms.every((term) => {
      return (
        searchableTokens.some((token) => token.includes(term)) ||
        searchableStr.includes(term)
      );
    });

    if (!allTermsMatch) return null;

    // Calculate match score: name matches score higher than content matches
    let score = 1;
    const fileNameTokens = tokenize(fileName);
    const fileNameStr = fileNameTokens.join(" ");
    const contentTokens = tokenize(fileContent);
    const contentStr = contentTokens.join(" ");

    searchTerms.forEach((term) => {
      // Name matches get 2x weight
      const nameIndex = fileNameStr.indexOf(term);
      if (nameIndex !== -1) {
        score += Math.max(0, 2 - nameIndex / 100);
      } else {
        // Content matches get 1x weight
        const contentIndex = contentStr.indexOf(term);
        if (contentIndex !== -1) {
          score += Math.max(0, 1 - contentIndex / 100);
        }
      }
    });

    return score;
  }

  /**
   * Updates visibility of file rows based on search query.
   * Maintains scroll position by setting fixed height during transition.
   */
  function updateFileListDisplay(searchQuery: string): void {
    const fileRows = document.querySelectorAll<HTMLDivElement>(".file-row");
    const fileList = document.querySelector<HTMLUListElement>(".file-list");

    if (!fileList) {
      console.error("File list not found");
      return;
    }

    // Prevent scroll jump during filtering
    const scrollableHeight = fileList.offsetHeight;
    if (scrollableHeight > 0) {
      fileList.style.height = `${scrollableHeight}px`;
    }

    const searchTerms = tokenize(searchQuery);
    const results: SearchResult[] = [];

    // Evaluate all rows and collect results
    fileRows.forEach((row) => {
      const fileNameElement = row.querySelector(".file-name");
      if (!fileNameElement?.textContent) return;

      const fileName = fileNameElement.textContent;
      const fileContent = row.dataset.fileContent || "";
      const matchScore = performFullTextSearch(
        fileName,
        fileContent,
        searchTerms,
      );

      if (matchScore !== null) {
        results.push({ element: row, matchScore });
        row.style.display = "flex";
      } else {
        row.style.display = "none";
      }
    });

    // Sort results by match score (highest first)
    results.sort((a, b) => b.matchScore - a.matchScore);

    // Reorder elements in DOM based on relevance
    results.forEach(({ element }) => {
      fileList.appendChild(element);
    });

    fileList.style.height = "auto";
  }

  // Initialize search form
  const searchForm = document.querySelector<HTMLFormElement>("search form");
  const searchInput = document.querySelector<HTMLInputElement>("search input");

  if (!searchInput) {
    console.error("Search input not found");
  } else {
    // Prevent form submission
    searchForm?.addEventListener("submit", (event) => {
      event.preventDefault();
    });

    // Execute initial search if input has value
    if (searchInput.value) {
      updateFileListDisplay(searchInput.value);
    }

    // Listen for search input changes
    searchInput.addEventListener("input", (event) => {
      const target = event.target as HTMLInputElement;
      updateFileListDisplay(target.value);
    });
  }
</script>

<div id="file-list-container" style="padding: 1rem 0;">
  <search>
    <form style="margin-bottom: 2rem;">
      <label for="search" style="margin-right: 1rem;">Search</label>
      <input type="search" id="search" name="search" />
    </form>
  </search>

  <ul class="file-list">
    {
      files.map((file) => (
        <li
          id={"folder-" + file.id.toString()}
          class="file-row"
          data-file-content={file.html.toLowerCase()}
        >
          <div class="file-name">
            <a href={`/file/${file.id}`} title={file.name}>
              {file.name}
            </a>
          </div>

          <ButtonMenu
            id={`file-${file.id}-menu`}
            items={[
              {
                label: "Copy",
                url: `/move/file/${file.id}`,
                verb: "GET",
                target: "#modal-container",
                swap: "innerHTML",
              },
              {
                label: "Delete",
                url: folderId
                  ? `/folder/${folderId}/file/${file.id}/delete/confirm`
                  : `/file/${file.id}/delete/confirm`,
                verb: "GET",
                target: "#modal-container",
                swap: "innerHTML",
              },
            ]}
          />
        </li>
      ))
    }
  </ul>
</div>

<style>
  input[type="search"] {
    -webkit-appearance: none;
    appearance: none;
    border: inherit;
  }

  .file-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(285px, 1fr));
    grid-gap: 1.5rem;
    grid-auto-rows: min-content;
  }

  .file-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: var(--card-background);
    border: 1px solid var(--black);
    border-radius: 4px;
    padding: 0.5rem 1rem;
    margin: 0.5rem 0;
    list-style: none;
    height: fit-content;
  }

  .file-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .file-name:focus-within {
    outline: auto;
  }

  /* Mobile */
  @media (max-width: 37.5em) {
    search label {
      display: block;
      margin-bottom: 0.5rem;
    }

    search input {
      width: 100%;
    }

    .file-list {
      grid-template-columns: repeat(auto-fill, 100%);
    }

    .file-row {
      padding-right: 0.5rem;
    }
  }
</style>
